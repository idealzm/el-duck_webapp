# YooKassa (YOUR credentials - NEVER commit real keys!)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key

# Telegram Bot Token (YOUR bot token - NEVER commit real token!)
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username

# Server configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Admin Telegram IDs (comma-separated for multiple admins)
# Example: "729705340,123456789,987654321"
ADMIN_TELEGRAM_ID=your_telegram_id_here

# Session secret for admin authentication (CHANGE IN PRODUCTION!)
SESSION_SECRET=change-this-to-a-random-secure-string-in-production

# Your domain for YooKassa return URLs
DOMAIN=https://your-domain.com
